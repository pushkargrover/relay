{
  "description": "context-handoff: per-turn 90% context check (UserPromptSubmit) with a compaction backstop (PreCompact). Both a PowerShell and an sh command are registered per event; the one that does not exist on the current OS fails silently (non-blocking), and trigger.sh additionally no-ops on Windows so the pair never double-fires.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}\\scripts\\trigger.ps1\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/scripts/trigger.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}\\scripts\\trigger.ps1\"",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/scripts/trigger.sh\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
